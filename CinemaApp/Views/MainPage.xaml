<Page x:Class="CinemaApp.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Афиша">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Background="#EEE">
            <TextBox x:Name="TxtSearch" Width="200" Margin="10" TextChanged="FilterChanged"/>
            <ComboBox x:Name="CmbSort" Width="120" Margin="10" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Имя" IsSelected="True"/>
                <ComboBoxItem Content="Рейтинг"/>
            </ComboBox>
            <Button x:Name="BtnProfile" Content="Профиль" Click="BtnProfile_Click" Margin="50,10"/>
        </StackPanel>

        <ListBox x:Name="ListMovies"
         Grid.Row="1"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         MouseDoubleClick="ListMovies_MouseDoubleClick">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Margin="15" Background="White">
                        <StackPanel>
                            <Border Height="320" Width="220" Background="#F0F0F0" CornerRadius="8">
                                <Image Source="{Binding PosterPath}" Stretch="Uniform"/>
                            </Border>

                            <TextBlock Text="{Binding Title}"
                           FontWeight="Bold"
                           FontSize="16" 
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>

                            <TextBlock Text="{Binding Genres}" 
                           FontSize="12" 
                           Foreground="Gray" 
                           FontStyle="Italic"
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,5"/>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}'}" 
                               FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding AgeRating}" 
                               Foreground="Red" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Page>