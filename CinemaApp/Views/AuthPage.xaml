<Page x:Class="CinemaApp.Views.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация">
    <Grid Background="#F0F4F8">
        <Border Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="10" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🎬 CinemaApp" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="TextBoxLogin" Height="36" FontSize="14" Padding="8,6"
                         BorderBrush="#CCC" BorderThickness="1"/>

                <TextBlock Text="Пароль" FontSize="13" Foreground="#555" Margin="0,12,0,4"/>
                <PasswordBox x:Name="PasswordBoxPassword" Height="36" FontSize="14" Padding="8,6"
                               BorderBrush="#CCC" BorderThickness="1"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="Red" FontSize="12"
                           Margin="0,8,0,0" TextWrapping="Wrap"/>

                <Button x:Name="BtnLogin" Content="Войти" Height="38" Margin="0,16,0,0"
                        Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Hyperlink Click="ToRegister_Click">Нет аккаунта? Зарегистрироваться</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>