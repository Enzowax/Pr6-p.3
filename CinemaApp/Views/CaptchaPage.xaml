<Page x:Class="CinemaApp.Views.CaptchaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Подтверждение капчи">
    <Grid Background="#F0F4F8">
        <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="10" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🔒 Подтверждение" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,8"/>
                <TextBlock Text="Слишком много неудачных попыток. Введите капчу:" 
                           FontSize="12" Foreground="#777" HorizontalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <Image x:Name="CaptchaImage" Height="70" Margin="0,0,0,4"/>

                <Button Content="🔄 Обновить" HorizontalAlignment="Right" FontSize="11"
                        Padding="6,2" Cursor="Hand" Click="RefreshCaptcha_Click" Margin="0,0,0,12"
                        Background="Transparent" BorderBrush="#CCC"/>

                <TextBlock Text="Введите текст с картинки:" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="TextBoxCaptcha" Height="36" FontSize="14" Padding="8,6"
                         BorderBrush="#CCC" BorderThickness="1"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="Red" FontSize="12" Margin="0,8,0,0"/>

                <Button Content="Продолжить" Height="38" Margin="0,16,0,0"
                        Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnConfirm_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Hyperlink Click="BackToLogin_Click">← Назад к авторизации</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>