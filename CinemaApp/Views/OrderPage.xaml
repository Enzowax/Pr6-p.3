<Page x:Class="CinemaApp.Views.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление заказа" Background="White">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,40,0">
            <Border Background="#EEE" 
                    Height="450" 
                    VerticalAlignment="Top" 
                    CornerRadius="8" 
                    ClipToBounds="True">
                <Image x:Name="ImgPoster"
                       Stretch="Uniform" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="TxtMovieTitle" FontSize="24" FontWeight="Bold" Margin="0,20,0,5" TextWrapping="Wrap"/>
            <TextBlock x:Name="TxtGenres" Foreground="DarkBlue" FontSize="14" Margin="0,0,0,10" FontWeight="SemiBold"/>
            <TextBlock x:Name="TxtDescription" Foreground="#444" FontSize="13" TextWrapping="Wrap" MaxHeight="150"/>
        </StackPanel>

        <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="15" Padding="30" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="ДЕТАЛИ ЗАКАЗА" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="DarkBlue"/>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Зал:" Foreground="Gray"/>
                    <TextBlock x:Name="TxtHall" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Дата и время:" Foreground="Gray"/>
                    <TextBlock x:Name="TxtDateTime" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Выбранные места:" Foreground="Gray"/>
                    <TextBlock x:Name="TxtSeats" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="DarkBlue"/>
                </Grid>

                <Separator Margin="0,20"/>

                <Grid>
                    <TextBlock Text="ИТОГО К ОПЛАТЕ" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotal" HorizontalAlignment="Right" FontSize="28" FontWeight="Bold" Foreground="DarkGreen"/>
                </Grid>

                <Button Content="ПОДТВЕРДИТЬ ПОКУПКУ" 
                        Click="BtnFinalConfirm_Click"
                        Margin="0,40,0,0" Height="55" 
                        Background="DarkBlue" Foreground="White" 
                        FontWeight="Bold" FontSize="16">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Назад к выбору мест" 
                        Click="BtnBack_Click"
                        Margin="0,10,0,0" Background="Transparent" 
                        BorderThickness="0" Foreground="Gray" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>