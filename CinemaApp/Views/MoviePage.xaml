<Page x:Class="CinemaApp.Views.MoviePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Фильм">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#EEE" 
            Height="450" 
            VerticalAlignment="Top" 
            CornerRadius="8" 
            ClipToBounds="True">
            <Image x:Name="ImgPoster"
               Stretch="Uniform" 
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Column="2">
            <TextBlock x:Name="TxtTitle"
                   FontSize="28"
                   FontWeight="Bold"
                   TextWrapping="Wrap"/>

            <TextBlock x:Name="TxtGenres" FontSize="14" Foreground="DarkBlue" Margin="0,5,0,0" FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock x:Name="TxtRating" 
                           FontSize="16" 
                           FontWeight="Medium" 
                           Margin="0,0,15,0"/>
                <TextBlock x:Name="TxtAgeRating" 
                           Foreground="Red" 
                           FontWeight="Bold" 
                           FontSize="16"/>
            </StackPanel>

            <TextBlock x:Name="TxtDesc"
                   FontSize="14"
                   Margin="0,15,0,25"
                   TextWrapping="Wrap"
                   Foreground="#333"/>

            <TextBlock Text="Доступные сеансы:"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,10,0,15"/>

            <ItemsControl x:Name="ListSessions">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="15"
                            Margin="0,0,0,12"
                            Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding DateTime, StringFormat=dd.MM HH:mm}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Width="110"/>

                                <TextBlock Grid.Column="1" 
                                       Text="{Binding Halls.Name}"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       Margin="10,0"/>

                                <TextBlock Grid.Column="2" 
                                       Text="{Binding Price, StringFormat={}{0} ₽}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="20,0"/>

                                <Button Grid.Column="3" 
                                    Content="Выбрать места"
                                    Padding="15,5"
                                    Background="DarkBlue"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="BtnSession_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="← Назад к списку"
                HorizontalAlignment="Left"
                Width="150"
                Height="35"
                Margin="0,20,0,0"
                Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Page>