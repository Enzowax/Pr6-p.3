<Page x:Class="CinemaApp.Views.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Выбор мест">

    <Page.Resources>
        <Style x:Key="SeatStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="seatBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="15">
                            <TextBlock Text="{Binding Number}" 
                                       FontSize="10" 
                                       Foreground="Transparent" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="seatBorder" Property="Background" Value="DarkBlue"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="seatBorder" Property="Background" Value="DarkRed"/>
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TxtMovieTitle" FontSize="26" FontWeight="Bold" Foreground="#222"/>
                <TextBlock x:Name="TxtSessionInfo" FontSize="14" Foreground="#777" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" 
                    Content="← Назад к фильму" 
                    Click="BtnBack_Click"
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="Gray" 
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    FontSize="14"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" Margin="0,40">
                <Border Background="#F2F2F2" Height="40" Width="500" CornerRadius="4" Margin="0,0,0,60">
                    <TextBlock Text="Э К Р А Н" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#999" FontWeight="Bold"/>
                </Border>

                <ItemsControl x:Name="RowsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="{Binding RowNumber}" Width="30" Foreground="LightGray" VerticalAlignment="Center" TextAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding Seats}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton Style="{StaticResource SeatStyle}" 
                                                          IsEnabled="{Binding IsAvailable}" 
                                                          DataContext="{Binding}"
                                                          Click="Seat_Click"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding RowNumber}" Width="30" Foreground="LightGray" VerticalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="30,20">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="#E0E0E0" Margin="0,0,8,0"/>
                    <TextBlock Text="Свободно" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="12"/>

                    <Ellipse Width="12" Height="12" Fill="DarkBlue" Margin="0,0,8,0"/>
                    <TextBlock Text="Выбрано" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="12"/>

                    <Ellipse Width="12" Height="12" Fill="DarkRed" Opacity="0.5" Margin="0,0,8,0"/>
                    <TextBlock Text="Занято" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Очистить выбор" 
                            Click="BtnClearSelection_Click"
                            Margin="0,0,15,0"
                            Padding="15,0"
                            Background="Transparent" 
                            BorderThickness="1" 
                            BorderBrush="#CCC"
                            Foreground="#666" 
                            Cursor="Hand" 
                            FontSize="13"
                            Height="45">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="КУПИТЬ" 
                            Click="BtnReserve_Click"
                            Width="200" Height="45"
                            Background="DarkBlue" 
                            Foreground="White" 
                            FontWeight="Bold"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>