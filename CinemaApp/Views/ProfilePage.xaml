<Page x:Class="CinemaApp.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль">

    <Grid Margin="20">

        <StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Назад"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Выйти из аккаунта"
                        Width="150"
                        Click="Logout_Click"/>
            </StackPanel>

            <TextBlock x:Name="TxtUser"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,10,0,10"/>

            <DataGrid x:Name="GridTickets"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фильм"
                                        Binding="{Binding Sessions.Movies.Title}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Место"
                                        Binding="{Binding Seats.Number}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Sessions.DateTime}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Цена"
                                        Binding="{Binding Sessions.Price}"
                                        Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>
</Page>
